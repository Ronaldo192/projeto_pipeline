# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pipeline
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline123

# MinIO – credenciais root (somente para admin/console)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# MinIO – usuário de serviço do pipeline (usar nos scripts Python)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=pipeline_user
MINIO_SECRET_KEY=pipeline_pass123
MINIO_SECURE=false

# Kestra
KESTRA_URL=http://localhost:8080

# Metabase
METABASE_URL=http://localhost:3000

# Pipeline
PIPELINE_ENV=development
LOG_LEVEL=INFO
